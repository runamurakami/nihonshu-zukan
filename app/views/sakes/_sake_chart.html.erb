<div>
  <h2 class="text-2xl font-bold text-center mb-6">
    月ごとの日本酒登録数
  </h2>

  <canvas id="sakeChart"></canvas>
</div>

<script>
document.addEventListener("turbo:load", () => {

  const ctx = document.getElementById("sakeChart");
  if (!ctx) return;

  const labels = <%= raw @sake_counts_by_month.keys.map { |d| d.strftime("%Y-%m") }.to_json %>;
  const data = <%= raw @sake_counts_by_month.values.to_json %>;

  new Chart(ctx, {
    type: "bar",
    data: {
      labels: labels,
      datasets: [{
        label: "登録した日本酒",
        data: data,
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            stepSize: 1
          }
        }
      }
    }
  });

});
</script>