<div class="grid grid-cols-2 gap-8">
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-2xl font-bold text-center mb-6">
      月ごとの日本酒登録数
    </h2>
    <div class="h-64">
      <canvas id="sakeCountChart"></canvas>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-2xl font-bold text-center mb-6">
      味の傾向
    </h2>
    <div class="h-64">
      <canvas id="tasteChart"></canvas>
    </div>
  </div>
</div>
<script>
document.addEventListener("turbo:load", () => {

  const sakeCtx = document.getElementById("sakeCountChart");
  if (sakeCtx) {

    const labels = <%= raw @sake_counts_by_month.keys.map { |d| d.strftime("%Y-%m") }.to_json %>;
    const data = <%= raw @sake_counts_by_month.values.to_json %>;

    new Chart(sakeCtx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [{
          label: "登録した日本酒",
          data: data,
          borderWidth: 1
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize: 1
            }
          }
        }
      }
    });
  }

  const tasteCtx = document.getElementById("tasteChart");
  if (tasteCtx) {
    new Chart(tasteCtx, {
      type: "doughnut",
      data: {
        labels: <%= raw @tag_counts.keys.to_json %>,
        datasets: [{
          data: <%= raw @tag_counts.values.to_json %>
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          }
        }
      }
    });
  }

});
</script>