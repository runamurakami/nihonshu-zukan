<div x-data="{ tab: 'recent' }" class="max-w-5xl mx-auto mt-12">
  <!-- タブ -->
  <div class="flex gap-2">
    <button class="px-6 py-3 rounded-t-2xl font-semibold transition"
      :class="tab === 'recent' ? 'bg-white' : 'bg-blue-100 text-gray-500'" @click="tab='recent'">
      最近登録した日本酒
    </button>
    <button class="px-6 py-3 rounded-t-2xl font-semibold transition"
     :class="tab === 'map' ? 'bg-white' : 'bg-blue-100 text-gray-500'" @click="tab='map'">
      マップ
    </button>
    <button class="px-6 py-3 rounded-t-2xl font-semibold transition"
      :class="tab === 'graph' ? 'bg-white' : 'bg-blue-100 text-gray-500'" @click="tab='graph'">
      グラフ
    </button>
    <button class="px-6 py-3 rounded-t-2xl font-semibold transition"
      :class="tab === 'badge' ? 'bg-white' : 'bg-blue-100 text-gray-500'" @click="tab='badge'">
      バッジ
    </button>
  </div>
  <!-- タブ切替コンテンツ -->
  <div class="bg-white rounded-b-2xl rounded-tr-2xl p-8 min-h-[500px]">
    <!-- 最近登録した日本酒タブ -->
    <div x-show="tab === 'recent'">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold">最近登録した日本酒</h1>
        <%= link_to "日本酒一覧へ →",
              sakes_path,
              class: "text-sm font-semibold text-indigo-600 hover:underline" %>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% if @recent_sakes.present? %>
        <%= render partial: "sakes/sake_card",
                   collection: @recent_sakes,
                   as: :sake %>
      <% else %>
        <p class="text-gray-500">まだ日本酒が登録されていません。</p>
      <% end %>
      </div>
    </div>
    <!-- マップタブ -->
    <div x-show="tab === 'map'">
      xxx
    </div>
    <!-- グラフタブ -->
    <div x-show="tab === 'graph'">
      <%= render "sakes/sake_chart" %>
    </div>
    <!-- バッジタブ -->
    <div x-show="tab === 'badge'">
    </div>
  </div>
</div>
